# NAS connection - use your Synology NAS IP or hostname
NAS_HOST=192.168.1.100

# API Keys - find these in each service's config
SONARR_API_KEY=your_sonarr_api_key
RADARR_API_KEY=your_radarr_api_key
SABNZBD_API_KEY=your_sabnzbd_api_key
PROWLARR_API_KEY=your_prowlarr_api_key
READARR_API_KEY=your_readarr_api_key
BAZARR_API_KEY=your_bazarr_api_key
SEERR_API_KEY=your_seerr_api_key

# qBittorrent uses session auth (no API key)
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

# Service ports (defaults shown - change if different)
SONARR_PORT=8989
RADARR_PORT=7878
SABNZBD_PORT=8080
QBITTORRENT_PORT=8090
PROWLARR_PORT=9696
READARR_PORT=8787
BAZARR_PORT=6767
SEERR_PORT=5055
GLUETUN_PORT=8005
